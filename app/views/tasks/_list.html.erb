<h2 class="text-3xl font-bold text-dusk-blue">
  <i class="fa-solid fa-robot"></i>
  AIがタスクを整理しました！
</h2>
<p class="mt-3 text-dusty-denim">
  内容は自由に編集できます。<br>
  ドラッグで並び替えが可能です。
</p>

<div data-controller="task-order">
  <div data-task-order-target="list">
    <% tasks.each_with_index do |task, index| %>
      <div data-task-order-target="item" data-id="<%= task.id %>">
        <div data-controller="task-form" class="m-5 p-4 relative border-2 border-gray-200 text-dusk-blue hover:-translate-y-1 hover:scale-105">
          <div data-task-form-target="display">
            <p class="hover:opacity-60">
              <%= task.content %>
            </p>
            <div class="flex mt-2">
              <button type="button" data-action="task-form#edit"
                data-testid="edit-task-button"
                class="pr-2 hover:opacity-60">
                <i class="fa-solid fa-pencil"></i>
              </button>
              <%= button_to situation_task_path(situation, task), method: :delete, class: "hover:opacity-60", data: { turbo_confirm: '本当に削除しますか？', testid: "delete-task-button-#{task.id}" } do %>
                <i class="fa-solid fa-trash"></i>
              <% end %>
            </div>
          </div>

          <div data-task-form-target="form" class="hidden p-9">
            <%= form_with model: [situation, task], method: :patch do |f| %>
              <%= f.text_field :content,
                class: "h-10 w-full appearance-none rounded border-2 border-gray-200 bg-gray-200 leading-tight text-gray-700 focus:bg-white focus:outline-none",
                data: {
                  task_edit_target: "input",
                  testid: "edit-task-content-input"
                }
              %>
              <%= f.button type: "submit", class: "bg-dusty-denim hover:opacity-60 text-xs text-white font-bold mt-3 py-2 px-4 rounded", data: { testid: "update-task-button" } do %>
                <i class="fa-solid fa-check"></i>
              <% end %>
              <button type="button" data-action="task-form#editCancel" class="bg-dusty-denim hover:opacity-60 text-xs text-white font-bold mt-3 py-2 px-4 rounded">
                <i class="fa-solid fa-x"></i>
              </button>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="m-5">
    <%= render "tasks/create_form", situation: situation, new_task: new_task %>
    <button>入力内容を見直す</button><br>

    <%= form_with url: situation_task_positions_path(situation), method: :patch, data: { action: "submit->task-order#buildHiddenFields" } do |f| %>
      <div data-task-order-target="hiddenFields"></div>
      <%= f.submit "完了", class: "bg-dusty-denim hover:opacity-60 text-white font-bold mt-3 py-2 px-4 rounded" %>
    <% end %>
  </div>
</div>
